<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header bar (drag handle) -->
    <LinearLayout
        android:id="@+id/overlay_header"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:background="#CC1A237E">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_translate"
            android:tint="#FFFFFF"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_minimize"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_minimize"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="minimize" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="close" />
    </LinearLayout>

    <!-- Translation content card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/content_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#E8F0FE">

        <ScrollView
            android:id="@+id/scroll_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="300dp"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Original text label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/original_text"
                    android:textSize="10sp"
                    android:textColor="#7986CB"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <!-- Original text -->
                <TextView
                    android:id="@+id/tv_original_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/waiting_for_capture"
                    android:textSize="12sp"
                    android:textColor="#424242"
                    android:maxLines="6"
                    android:ellipsize="end"
                    android:layout_marginBottom="10dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#C5CAE9"
                    android:layout_marginBottom="10dp" />

                <!-- Translated text label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/translated_text"
                    android:textSize="10sp"
                    android:textColor="#1A237E"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <!-- Translated text -->
                <TextView
                    android:id="@+id/tv_translated_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/waiting_for_translation"
                    android:textSize="14sp"
                    android:textColor="#0D47A1"
                    android:textStyle="bold" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</LinearLayout>
